<% layout("/layouts/boilerplate") %>

<div class="show-page-container py-5">
  <!-- ================= TITLE ================= -->
  <div class="row mb-5">
    <div class="col-12 col-lg-8 offset-lg-2 text-center">
      <h1 class="display-4 fw-bold mb-2 text-dark lh-sm">
        <%= listing.title %>
      </h1>
      <div
        class="d-flex justify-content-center align-items-center gap-2 opacity-75 mb-4"
      >
        <i class="fas fa-map-marker-alt text-danger"></i>
        <span class="fw-medium">
          <%= listing.location %>, <%= listing.country %>
        </span>
      </div>
    </div>
  </div>

  <!-- ================= LISTING CARD ================= -->
  <div class="row mb-5">
    <div class="col-12 col-lg-10 col-xl-8 mx-auto">
      <div class="card show-card h-100 overflow-hidden">
        <img src="<%= listing.image %>" class="card-img-top hero-img" />

        <div class="card-body p-5">
          <!-- Owner -->
          <div class="d-flex justify-content-between mb-4 border-bottom pb-3">
            <div class="bg-light rounded-pill px-3 py-2">
              <i class="fas fa-user me-1"></i>
              <strong>
                <%= listing.owner?.username || "Anonymous Host" %>
              </strong>
            </div>
          </div>

          <!-- Description -->
          <h3 class="fw-bold mb-3">About this stay</h3>
          <p class="text-muted mb-4"><%= listing.description %></p>

          <!-- Price -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="text-danger fw-bold fs-3">
              ₹ <%= listing.price.toLocaleString("en-IN") %> /night
            </div>
            <div class="text-muted">
              <i class="fas fa-map-marker-alt text-danger"></i>
              <%= listing.location %>, <%= listing.country %>
            </div>
          </div>

          <!-- ✅ BOOK NOW BUTTON -->
          <% if(currUser && currUser.role === "user"){ %>
          <form action="/bookings/<%= listing._id %>" method="POST">
            <button class="btn btn-danger w-100 rounded-pill fw-bold py-2">
              🏨 Book Now
            </button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <style>
    .host-btn {
      transition: all 0.3s ease;
      border: none;
    }

    .host-btn:hover {
      transform: translateY(-4px) scale(1.05);
      box-shadow: 0 12px 25px rgba(0, 0, 0, 0.25);
      filter: brightness(1.1);
    }
  </style>

  <!-- HOST ACTIONS -->
  <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) {
  %>

  <div class="row justify-content-center mb-5">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card border-0 shadow-lg rounded-4 p-4 text-center">
        <h5 class="fw-bold mb-4">Host Controls</h5>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
          <a
            href="/listings/<%= listing._id %>/edit"
            class="btn host-btn btn-lg px-4 py-3 fw-bold rounded-pill text-white d-flex align-items-center justify-content-center gap-2"
            style="
              background: linear-gradient(135deg, #fbbf24, #f97316);
              min-width: 180px;
            "
          >
            <i class="fas fa-pen"></i>
            Edit
          </a>

          <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=DELETE"
          >
            <button
              class="btn host-btn btn-lg px-4 py-3 fw-bold rounded-pill text-white d-flex align-items-center justify-content-center gap-2"
              style="
                background: linear-gradient(135deg, #ef4444, #b91c1c);
                min-width: 180px;
              "
              onclick="return confirm('⚠️ Delete this listing permanently?')"
            >
              <i class="fas fa-trash"></i>
              Delete
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <% } %>

  <!-- ================= REVIEW SECTION ================= -->
  <% if(!currUser || !listing.owner || !currUser._id.equals(listing.owner._id))
  { %>

  <div class="row justify-content-center mb-5">
    <div class="col-12 col-lg-8">
      <div class="card shadow-sm p-4 rounded-4">
        <h4 class="fw-bold mb-4">⭐ Leave a Review</h4>

        <% if(currUser){ %>
        <form
          action="/listings/<%=listing._id%>/reviews"
          method="POST"
          novalidate
          class="needs-validation"
        >
          <div class="mb-3">
            <label class="form-label fw-semibold">Rating</label>
            <input
              type="range"
              min="1"
              max="5"
              name="review[rating]"
              class="form-range"
            />
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Comment</label>
            <textarea
              name="review[comment]"
              class="form-control"
              rows="4"
              required
            ></textarea>
            <div class="invalid-feedback">Please write something</div>
          </div>

          <button class="btn btn-danger rounded-pill px-4">
            Submit Review
          </button>
        </form>
        <% } else { %>
        <p class="text-muted">Please login to add a review.</p>
        <% } %>
      </div>
    </div>
  </div>

  <% } %>

  <!-- ================= ALL REVIEWS ================= -->
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">
      <h4 class="fw-bold mb-4">💬 All Reviews</h4>

      <div class="row g-3">
        <% for(let review of listing.reviews){ %>

        <div class="col-md-6">
          <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
              <h6 class="fw-bold text-dark mb-2">
                <i class="fas fa-user-circle me-1"></i>
                <%= review.author?.username || "User" %>
              </h6>

              <p class="text-warning mb-2">⭐ <%= review.rating %> / 5</p>
              <p class="text-muted"><%= review.comment %></p>

              <% if(currUser && review.author &&
              currUser._id.equals(review.author._id)){ %>
              <form
                method="POST"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              >
                <button class="btn btn-sm btn-outline-danger rounded-pill">
                  Delete
                </button>
              </form>
              <% } %>
            </div>
          </div>
        </div>

        <% } %>
      </div>
    </div>
  </div>
</div>
