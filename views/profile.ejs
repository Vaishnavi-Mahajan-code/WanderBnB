<% layout('/layouts/boilerplate') %>
<div class="container py-5" style="padding-top: 120px; min-height: 80vh">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-6">
      <!-- Profile Header -->
      <div class="text-center mb-5">
        <div class="mx-auto mb-4" style="width: 120px; height: 120px">
          <% if(currUser.avatar) { %>
          <img
            src="<%= currUser.avatar %>"
            class="rounded-circle shadow-lg border border-4 border-white w-100 h-100 object-fit-cover"
            alt="<%= currUser.username %>"
          />
          <% } else { %>
          <div
            class="bg-gradient rounded-circle d-flex align-items-center justify-content-center text-white fw-bold fs-1 shadow-lg border border-4 border-white w-100 h-100"
            style="background: linear-gradient(135deg, #fe424d, #ff5a6a)"
          >
            <%= currUser.username[0]?.toUpperCase() %>
          </div>
          <% } %>
        </div>
        <h1 class="display-5 fw-bold text-dark mb-2">
          <%= currUser.username %>
        </h1>
        <p class="lead text-muted mb-4">
          Host since <%= new Date(currUser.createdAt).getFullYear() %>
        </p>
        <span
          class="badge bg-danger bg-opacity-20 text-danger px-4 py-3 fs-5 fw-semibold rounded-pill"
        >
          <i class="fas fa-crown me-2"></i>Verified Host
        </span>
      </div>

      <!-- Profile Stats -->
      <div class="row g-4 mb-5">
        <div class="col-md-4 text-center">
          <div class="h3 fw-bold text-danger mb-1">
            <%= listingsCount || 0 %>
          </div>
          <div class="text-muted">Active Listings</div>
        </div>
        <div class="col-md-4 text-center">
          <div class="h3 fw-bold text-primary mb-1">
            <%= bookingsCount || 0 %>
          </div>
          <div class="text-muted">Bookings</div>
        </div>
        <div class="col-md-4 text-center">
          <div class="h3 fw-bold text-success mb-1">
            <%= reviewsCount || 0 %>
          </div>
          <div class="text-muted">Reviews</div>
        </div>
      </div>

      <!-- Profile Details Card -->
      <div
        class="card border-0 shadow-xl rounded-4 overflow-hidden"
        style="backdrop-filter: blur(20px)"
      >
        <div class="card-body p-5">
          <h2
            class="h3 fw-bold mb-4 pb-3 border-bottom border-light border-opacity-25"
          >
            <i class="fas fa-info-circle me-2 text-danger"></i>Host Details
          </h2>
          <div class="row g-4">
            <div class="col-md-6">
              <div class="d-flex align-items-center mb-3">
                <i class="fas fa-envelope text-danger fs-5 me-3 opacity-75"></i>
                <span class="fw-semibold"><%= currUser.email %></span>
              </div>
              <% if(currUser.phone) { %>
              <div class="d-flex align-items-center mb-3">
                <i class="fas fa-phone text-danger fs-5 me-3 opacity-75"></i>
                <span class="fw-semibold"><%= currUser.phone %></span>
              </div>
              <% } %>
            </div>
            <div class="col-md-6">
              <div class="d-flex align-items-start mb-3">
                <i
                  class="fas fa-calendar-check text-danger fs-5 me-3 mt-1 opacity-75"
                ></i>
                <div>
                  <strong>Member since:</strong><br />
                  <span class="text-muted"
                    ><%= new
                    Date(currUser.createdAt).toLocaleDateString('en-IN')
                    %></span
                  >
                </div>
              </div>
              <% if(currUser.bio) { %>
              <div class="d-flex align-items-start">
                <i
                  class="fas fa-quote-left text-danger fs-5 me-3 mt-1 opacity-75"
                ></i>
                <div>
                  <strong>About:</strong><br />
                  <p class="text-muted mb-0"><%= currUser.bio %></p>
                </div>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="row g-3 mt-5 justify-content-center">
        <div class="col-md-6 col-lg-4">
          <a
            href="/listings/new"
            class="btn btn-danger btn-lg w-100 py-3 shadow-xl rounded-pill fw-bold"
          >
            <i class="fas fa-plus-circle me-2"></i>New Listing
          </a>
        </div>
        <div class="col-md-6 col-lg-4">
          <a
            href="/listings/mine"
            class="btn btn-outline-danger btn-lg w-100 py-3 shadow-xl rounded-pill fw-bold"
          >
            <i class="fas fa-list me-2"></i>My Listings
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Profile Page Styles */
  .shadow-xl {
    box-shadow: 0 25px 70px rgba(0, 0, 0, 0.15) !important;
  }
  .bg-gradient {
    background: linear-gradient(135deg, #fe424d, #ff5a6a) !important;
  }
  .card {
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(20px);
  }
  @media (max-width: 768px) {
    .container {
      padding-left: 1.5rem !important;
      padding-right: 1.5rem !important;
    }
  }
</style>
