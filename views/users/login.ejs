<% layout("/layouts/boilerplate") %>

<div class="row mt-3" style="padding-top: 100px; padding-bottom: 150px">
  <h1
    class="col-6 offset-3 text-center mb-4 fw-bold"
    style="color: #2c3e50; font-size: 2.2rem"
  >
    Login to Wanderbnb
  </h1>
  <div class="col-6 offset-3">
    <form action="/login" method="post" class="needs-validation" novalidate>
      <!-- Username -->
      <div class="mb-3">
        <label for="username" class="form-label fw-semibold text-dark mb-2">
          <i class="fas fa-user me-1 text-danger"></i>Username
        </label>
        <input
          type="text"
          name="username"
          id="username"
          class="form-control form-control-lg shadow-sm border-danger-subtle login-input"
          placeholder="Enter your username"
          required
        />
        <div class="valid-feedback mt-1">Looks good!</div>
        <div class="invalid-feedback mt-1">Username required.</div>
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label for="password" class="form-label fw-semibold text-dark mb-2">
          <i class="fas fa-lock me-1 text-danger"></i>Password
        </label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control form-control-lg shadow-sm border-danger-subtle login-input"
          placeholder="Enter your password"
          required
        />
        <div class="invalid-feedback mt-1">Password required.</div>
      </div>

      <!-- Submit Button -->
      <div class="mb-4">
        <button
          type="submit"
          class="btn btn-danger w-100 py-3 fw-bold rounded-pill shadow-lg login-btn"
        >
          <i class="fas fa-sign-in-alt me-2"></i>Login
        </button>
      </div>

      <!-- Signup Link -->
      <div class="text-center pb-3">
        <p class="text-muted mb-0 small">
          Don't have an account?
          <a href="/signup" class="text-danger fw-semibold text-decoration-none"
            >Sign up here</a
          >
        </p>
      </div>
    </form>
  </div>
</div>
<script>
  /* Same validation script as before */
</script>
